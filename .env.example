APP_NAME="Aghay Sarafi"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Database (SQLite) ────────────────────────────────────────────────────────
# In Docker/Dokploy mount a persistent volume at /var/www/html/database so the
# SQLite file survives container redeploys.
DB_CONNECTION=sqlite
DB_DATABASE=/var/www/html/database/database.sqlite

# ── Session / Cache / Queue ──────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=your-domain.com
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── AWS S3 (optional — for offloading uploaded files) ────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-2
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Docker / Dokploy ─────────────────────────────────────────────────────────
# Mount persistent volumes:
#   /var/www/html/database   → stores database.sqlite
#   /var/www/html/storage/app → stores uploaded logos, signage images, etc.
RUN_MIGRATIONS=true
