{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "exchange-landing",
  "private": true,
  "workspaces": [
    "frontend",
    "api"
  ],
  "scripts": {
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:api": "npm --prefix api run dev",
    "build:frontend": "npm --prefix frontend run build",
